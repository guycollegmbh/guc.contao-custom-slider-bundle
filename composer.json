{
    "name": "guycollegmbh/contao-custom-slider-bundle",
    "type": "contao-bundle",
    "description": "Custom Slider extension for Contao Open Source CMS",
    "license": "LGPL-3.0-or-later",
    "authors": [
        {
            "name": "GUYCOLLEGMBH",
            "homepage": "https://www.guycolle.com/"
        }
    ],
    "require": {
        "contao/core-bundle": "^5.3"
    },
    "extra": {
        "contao-manager-plugin": "GUYCOLLEGMBH\\ContaoCustomSliderBundle\\ContaoManager\\Plugin",
        "logo": "data:image/svg+xml;base64,"
    },
    "autoload": {
        "psr-4": {
            "GUYCOLLEGMBH\\ContaoCustomSliderBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "GUYCOLLEGMBH\\ContaoCustomSliderBundle\\Tests\\": "tests/"
        }
    },
    "support": {
        "issues": "https://github.com/guycollegmbh/guc.contao-custom-slider-bundle/issues",
        "source": "https://github.com/guycollegmbh/guc.contao-custom-slider-bundle"
    }
}
